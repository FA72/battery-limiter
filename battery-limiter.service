[Unit]
Description=Battery charge limiter (40%%-80%%)
After=multi-user.target

[Service]
Type=simple
EnvironmentFile=-/etc/default/battery-limiter
ExecStart=/usr/local/bin/battery-limiter.sh
# Return full driver control on stop so phone doesn't stay limited
ExecStopPost=/bin/sh -c 'path="${CHARGER_CURRENT_MAX_PATH:-${SYS_CMAX:-}}"; restore_current="${STOP_CURRENT_MAX:-${CURRENT_DRIVER:-4800000}}"; if [ -z "$path" ]; then for candidate in /sys/class/power_supply/*/current_max; do [ -e "$candidate" ] || continue; path="$candidate"; break; done; fi; [ -n "$path" ] && echo "$restore_current" > "$path" || true'
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
