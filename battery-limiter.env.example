# Copy this file to battery-limiter.env before deployment if you need overrides.
# The deploy script uploads battery-limiter.env to /etc/default/battery-limiter when present.

CAP_LOW=40
CAP_HIGH=80
TEMP_LOCK_ENTER=450
TEMP_LOCK_EXIT=400
TICK_INTERVAL=300
RETRY_INTERVAL=10
TUNING_SETTLE=30
CURRENT_OFF=0
CURRENT_START=500000
CURRENT_STEP=100000
CURRENT_CEIL=1000000
CURRENT_DRIVER=4800000
RECOVERY_OFF_DWELL=3
RECOVERY_PRIME=1000000
RECOVERY_PRIME_SETTLE=15
RECOVERY_BOOST_SETTLE=12
# RECOVERY_BOOST defaults to CURRENT_DRIVER unless you need a separate boost value.
# STOP_CURRENT_MAX defaults to CURRENT_DRIVER unless you need a different restore value on service stop.

# Leave these unset to auto-detect the first power_supply node that exposes
# capacity, temp, status, and current_now in one place.
# BATTERY_GAUGE_BASE_PATH=/sys/class/power_supply/your-battery
# SYS_CAP=/sys/class/power_supply/your-battery/capacity
# SYS_TEMP=/sys/class/power_supply/your-battery/temp
# SYS_BQST=/sys/class/power_supply/your-battery/status
# SYS_CUR=/sys/class/power_supply/your-battery/current_now
# Leave these unset to auto-detect the first /sys/class/power_supply/*/current_max node.
# SYS_CMAX=/sys/class/power_supply/your-charger/current_max
# CHARGER_CURRENT_MAX_PATH=/sys/class/power_supply/your-charger/current_max
